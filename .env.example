# ============== GO-LIVE: see docs/GO-LIVE.md ==============

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: for running migrations locally
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Stripe (required for /pay and /dashboard/billing)
STRIPE_SECRET_KEY=sk_live_... or sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_... or pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from Stripe webhook endpoint
STRIPE_SUBSCRIPTION_PRICE_ID=price_...   # for landlord SaaS billing

# Resend (required for application/approve/reject/maintenance emails)
RESEND_API_KEY=re_...
EMAIL_FROM=Bannerman Leasing <noreply@yourdomain.com>
# LANDLORD_EMAIL=you@example.com   # optional: notify on new application

# Dashboard (optional; omit to allow any signed-in user with landlord row)
# DASHBOARD_STAFF_EMAILS=admin@example.com

# Screening (optional; mock used if unset)
# SCREENING_FEE_CENTS=3500
# CHECKR_API_KEY=
# RENTPREP_API_KEY=

# AI-generated state-specific leases and eviction notices (optional)
# OPENAI_API_KEY=sk-...
