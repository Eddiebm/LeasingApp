{
  "name": "leasing-app",
  "version": "1.0.0",
  "description": "Rental agency app: tenant applications, document uploads, screening, and lease generation for Bannerman Group",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cloudflare": "next build && npx @cloudflare/next-on-pages",
    "deploy": "npm run build:cloudflare && npx wrangler pages deploy --project-name=leasingapp",
    "start": "next start",
    "preview": "npx wrangler pages dev .vercel/output/static --compatibility-flags=nodejs_compat",
    "lint": "next lint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "next": "14.2.18",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "1.9.0",
    "vercel": "39.1.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "wrangler": "^3.78.0"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "vercel": "$vercel"
  }
}
